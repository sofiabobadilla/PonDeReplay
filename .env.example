## Example environment variables for PonDeReplay

# Ethereum RPC endpoint (mainnet/testnet)
ETH_RPC_URL = "https://eth-mainnet.example/v2/YOUR_KEY"

# Optional: separate fork URL if you want reads vs forks separated
ETH_FORK_URL = ""

# Optional: Etherscan API key used by `pondereplay replay-history`
ETHERSCAN_API_KEY = ""
